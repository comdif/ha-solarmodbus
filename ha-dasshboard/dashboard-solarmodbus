views:
  - type: panel
    path: overview
    title: Overview
    cards:
      - cardstyle: lite
        wide: false
        large_font: true
        show_solar: true
        show_battery: true
        show_grid: true
        center_no_grid: false
        card_height: 100%
        card_width: 100%
        decimal_places: 2
        decimal_places_energy: 1
        dynamic_line_width: true
        max_line_width: 4
        min_line_width: 1
        inverter:
          modern: true
          colour: "#9e9e9e"
          autarky: power
          model: deye
          auto_scale: true
          three_phase: false
          navigate: ""
          label_autarky: ""
          label_ratio: ""
        battery:
          energy: 0
          shutdown_soc: 20
          show_daily: true
          invert_flow: true
        battery2:
          energy: 0
          shutdown_soc: 20
          soc_end_of_charge: 100
          invert_power: false
          hide_soc: false
          colour: "#ffc0cb"
          show_remaining_energy: true
          remaining_energy_to_shutdown: false
          show_absolute: false
          auto_scale: true
          dynamic_colour: true
          linear_gradient: true
          animate: true
          path_threshold: 100
          navigate: ""
          invert_flow: false
        solar:
          show_daily: true
          mppts: 2
          invert_flow: false
        load:
          show_daily: true
          show_aux: false
          invert_flow: false
        grid:
          show_daily_buy: true
          show_daily_sell: false
          show_nonessential: true
        type: custom:sunsynk-power-flow-card
        entities:
          priority_load_243: sensor.solarmodbus_device_smartload_enable_status
          inverter_status_59: sensor.solarmodbus_device_running_status
          grid_connected_status_194: sensor.solarmodbus_device_grid_connected_status
          inverter_voltage_154: sensor.solarmodbus_device_load_voltage
          inverter_current_164: sensor.solarmodbus_device_current_l1
          inverter_current_l2: sensor.solarmodbus_device_current_l2
          inverter_power_175: sensor.solarmodbus_device_total_power
          inverter_l1_power: sensor.solarmodbus_device_inverter_l1_power
          inverter_l2_power: sensor.solarmodbus_device_inverter_l2_power
          load_frequency_192: sensor.solarmodbus_device_load_frequency
          essential_power: sensor.solarmodbus_device_load_l1_power
          grid_power_169: sensor.solarmodbus_device_total_grid_power
          grid_ct_power_172: sensor.solarmodbus_device_external_ct_l1_power
          grid_ct_l2_power: sensor.solarmodbus_device_external_ct_l2_power
          day_grid_import_76: sensor.solarmodbus_device_daily_energy_bought
          day_grid_export_77: sensor.solarmodbus_device_daily_energy_sold
          day_load_energy_84: sensor.solarmodbus_device_daily_load_consumption
          pv1_power_186: sensor.solarmodbus_device_pv1_power
          pv2_power_187: sensor.solarmodbus_device_pv2_power
          pv1_voltage_109: sensor.solarmodbus_device_pv1_voltage
          pv1_current_110: sensor.solarmodbus_device_pv1_current
          pv2_voltage_111: sensor.solarmodbus_device_pv2_voltage
          pv2_current_112: sensor.solarmodbus_device_pv2_current
          day_pv_energy_108: sensor.solarmodbus_device_daily_production
          aux_power_166: sensor.solarmodbus_device_micro_inverter_power
          battery_voltage_183: sensor.solarmodbus_device_battery_voltage
          battery_soc_184: sensor.solarmodbus_device_battery_soc
          battery_power_190: sensor.solarmodbus_device_battery_power
          battery_current_191: sensor.solarmodbus_device_battery_current
          day_battery_charge_70: sensor.solarmodbus_device_daily_battery_charge
          day_battery_discharge_71: sensor.solarmodbus_device_daily_battery_discharge
          alert: sensor.solarmodbus_device_alert
          use_timer_248: sensor.solarmodbus_device_grid_charge
        card_mod:
          style: |
            :host {
              height: auto !important;
              width: 100% !important;
            }
            ha-card {
              height: calc(100dvh - 110px) !important;
              max-height: calc(100dvh - 110px) !important;
              width: 100% !important;
              overflow: hidden;
            }

            @media (orientation: portrait) {
              ha-card {
                height: calc(100dvh - 180px) !important;
                max-height: calc(100dvh - 180px) !important;
              }
            }
