            heading_style: subtitle
          - type: custom:button-card
            entity: sensor.solarmodbus_device_time_of_use
            name: Time Of Use
            show_state: true
            icon: mdi:clock
            tap_action:
              action: call-service
              service: script.modbuswrite
              data:
                address: 248
                value: |
                  [[[
                    const current = parseInt(states['sensor.solarmodbus_device_time_of_use_raw'].state);
                    const tou = states['sensor.solarmodbus_device_time_of_use'].state;

                    if (tou === 'Enabled') {
                      return current - 1;
                    } else {
                      return current + 1;
                    }
                  ]]]
            state:
              - value: Enabled
                styles:
                  card:
                    - border: 2px solid green
                  icon:
